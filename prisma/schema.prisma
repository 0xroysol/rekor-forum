generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  USER
  MOD
  ADMIN
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  displayName String?
  avatar      String?
  bio         String?
  role        Role     @default(USER)
  points      Int      @default(0)
  reputation  Int      @default(0)
  postCount   Int      @default(0)
  rankId      String?
  title       String?
  coverImage  String?
  favoriteTeam String?
  location    String?
  twitterUrl  String?
  instagramUrl String?
  isOnline    Boolean  @default(false)
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())

  rank          Rank?          @relation(fields: [rankId], references: [id])
  threads       Thread[]
  posts         Post[]
  reactions     Reaction[]
  badges        UserBadge[]
  bookmarks     Bookmark[]
  notifications Notification[]
  reports       Report[]       @relation("Reporter")
  sentMessages  Message[]      @relation("Sender")
  conversations ConversationParticipant[]
  predictions   Prediction[]
  predictionPoints Int @default(0)
  chatMessages  ChatMessage[]

  // Profile comments
  profileCommentsWritten  ProfileComment[] @relation("ProfileCommentsWritten")
  profileCommentsReceived ProfileComment[] @relation("ProfileCommentsReceived")

  // Moderation
  bansReceived     UserBan[]     @relation("BansReceived")
  bansGiven        UserBan[]     @relation("BansGiven")
  warningsReceived UserWarning[] @relation("WarningsReceived")
  warningsGiven    UserWarning[] @relation("WarningsGiven")
  chatMutesReceived ChatMute[]   @relation("ChatMutesReceived")
  chatMutesGiven    ChatMute[]   @relation("ChatMutesGiven")

  isBanned    Boolean   @default(false)
  banReason   String?
  banExpiresAt DateTime?

  @@index([username])
  @@index([email])
}

model Rank {
  id       String  @id @default(cuid())
  name     String
  icon     String
  color    String
  minPosts Int     @default(0)
  special  Boolean @default(false)
  position Int     @default(0)
  users    User[]
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  icon        String
  description String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  icon        String
  description String
  color       String
  position    Int        @default(0)
  isVip       Boolean    @default(false)
  isCasino    Boolean    @default(false)
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  threads     Thread[]

  @@index([slug])
  @@index([parentId])
}

model Prefix {
  id      String   @id @default(cuid())
  label   String
  color   String
  threads Thread[]
}

model Thread {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  categoryId String
  authorId   String
  prefixId   String?
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  isFeatured Boolean  @default(false)
  isHot      Boolean  @default(false)
  viewCount  Int      @default(0)
  replyCount Int      @default(0)
  lastPostAt DateTime @default(now())
  createdAt  DateTime @default(now())

  category  Category   @relation(fields: [categoryId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  prefix    Prefix?    @relation(fields: [prefixId], references: [id])
  posts     Post[]
  tags      ThreadTag[]
  bookmarks Bookmark[]
  poll      Poll?

  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
  @@index([lastPostAt])
  @@index([createdAt])
}

model Post {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  editedAt  DateTime?

  thread    Thread     @relation(fields: [threadId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  reactions Reaction[]

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  threads ThreadTag[]
}

model ThreadTag {
  threadId String
  tagId    String
  thread   Thread @relation(fields: [threadId], references: [id])
  tag      Tag    @relation(fields: [tagId], references: [id])

  @@id([threadId, tagId])
}

model Reaction {
  id     String @id @default(cuid())
  postId String
  userId String
  emoji  String

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId, emoji])
  @@index([postId])
  @@index([userId])
}

model Conversation {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("Sender", fields: [senderId], references: [id])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String
  content         String
  isRead          Boolean  @default(false)
  relatedThreadId String?
  relatedUserId   String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  type       String
  targetId   String
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id])
}

model Bookmark {
  id       String @id @default(cuid())
  userId   String
  threadId String

  user   User   @relation(fields: [userId], references: [id])
  thread Thread @relation(fields: [threadId], references: [id])

  @@unique([userId, threadId])
}

model LiveMatch {
  id        String   @id @default(cuid())
  league    String
  homeTeam  String
  awayTeam  String
  homeScore Int      @default(0)
  awayScore Int      @default(0)
  minute    Int      @default(0)
  status    String   @default("upcoming")
  startTime DateTime
  createdAt DateTime @default(now())
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  content     String
  imageUrl    String?
  source      String
  sourceUrl   String
  category    String   @default("futbol")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([category])
  @@index([slug])
}

model Poll {
  id        String   @id @default(cuid())
  threadId  String   @unique
  question  String
  endsAt    DateTime?
  createdAt DateTime @default(now())

  thread  Thread       @relation(fields: [threadId], references: [id])
  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id       String @id @default(cuid())
  pollId   String
  text     String
  position Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id])
  votes PollVote[]
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id])
  option PollOption @relation(fields: [optionId], references: [id])

  @@unique([pollId, userId])
}

model ChatRoom {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  roomId    String   @default("genel")
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt])
  @@index([userId])
}

model ProfileComment {
  id        String   @id @default(cuid())
  authorId  String
  profileId String
  content   String
  createdAt DateTime @default(now())

  author  User @relation("ProfileCommentsWritten", fields: [authorId], references: [id])
  profile User @relation("ProfileCommentsReceived", fields: [profileId], references: [id])

  @@index([profileId, createdAt])
}

model UserBan {
  id        String    @id @default(cuid())
  userId    String
  bannedBy  String
  reason    String
  duration  String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user  User @relation("BansReceived", fields: [userId], references: [id])
  admin User @relation("BansGiven", fields: [bannedBy], references: [id])

  @@index([userId])
}

model UserWarning {
  id        String   @id @default(cuid())
  userId    String
  warnedBy  String
  reason    String
  createdAt DateTime @default(now())

  user  User @relation("WarningsReceived", fields: [userId], references: [id])
  admin User @relation("WarningsGiven", fields: [warnedBy], references: [id])

  @@index([userId])
}

model ChatMute {
  id        String    @id @default(cuid())
  userId    String
  mutedBy   String
  roomId    String
  reason    String?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user  User @relation("ChatMutesReceived", fields: [userId], references: [id])
  admin User @relation("ChatMutesGiven", fields: [mutedBy], references: [id])

  @@index([userId, roomId])
}

model Prediction {
  id           String   @id @default(cuid())
  userId       String
  matchId      String
  homeScore    Int
  awayScore    Int
  points       Int      @default(0)
  isProcessed  Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}
